{
  "name": "hop-framework",
  "version": "1.0.0",
  "description": "High-performance BDD automation testing framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hop": "./bin/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && bun build bin/cli.ts --outdir bin --target bun",
    "test": "bun test",
    "dev": "bun run bin/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cucumber/gherkin": "^28.0.0",
    "@cucumber/messages": "^25.0.0",
    "arktype": "latest",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "eta": "^3.5.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "allure-commandline": "^2.37.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "playwright-core": "^1.40.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Hop Team",
  "license": "MIT"
}
