{
  "name": "hop-framework",
  "version": "1.0.0",
  "description": "High-performance BDD automation testing framework",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "hop": "./bin/cli.js",
    "hop-framework": "./bin/cli.js",
    "create-hop": "./bin/create-hop.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && bun build bin/cli.ts --outdir bin --target bun && bun build bin/create-hop.ts --outdir bin --target bun",
    "test": "bun test",
    "dev": "bun run bin/cli.ts",
    "prepublishOnly": "npm run build",
    "report": "hop test --reporter allure && allure serve reports/allure-results",
    "report:generate": "hop test --reporter allure && allure generate reports/allure-results --clean -o reports/allure-report",
    "report:open": "allure serve reports/allure-results"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.0",
    "@cucumber/gherkin": "^28.0.0",
    "@cucumber/messages": "^25.0.0",
    "commander": "^12.0.0",
    "dotenv": "^17.3.1",
    "eta": "^3.5.0",
    "fast-xml-parser": "^5.5.6",
    "picocolors": "^1.1.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/bun": "latest",
    "@types/node": "^20.0.0",
    "allure-commandline": "^2.37.0",
    "typescript": "^5.3.0"
  },
  "peerDependencies": {
    "playwright-core": "^1.40.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Hop Team",
  "license": "MIT",
  "keywords": [
    "bdd",
    "testing",
    "gherkin",
    "cucumber",
    "api-testing",
    "e2e",
    "automation",
    "playwright",
    "load-testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ahmad-ubaidillah/hop.git"
  }
}
